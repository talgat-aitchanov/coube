# PostgreSQL connection — override for non-local environments
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/coube
SPRING_DATASOURCE_USERNAME=coube
SPRING_DATASOURCE_PASSWORD=coube

# HikariCP connection pool size (default: 10)
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10

# Active Spring profile: local | prod
SPRING_PROFILES_ACTIVE=local
